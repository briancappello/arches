# Build artifacts
out/
.aur-repo/
.pkg-cache/
.offline-cache/
*.log

# ─── Staged into ISO airootfs by Makefile ─────────────
# These are copies of source files (installer/, ansible/, platforms/)
# placed into iso/airootfs/ at build time. The originals are tracked.
iso/airootfs/opt/arches
iso/airootfs/usr/local/bin/arches-install
iso/airootfs/root/auto-install.toml

# Pre-built AUR repo (generated by internal _aur-repo target)
iso/airootfs/opt/arches-repo/

# Generated by _stage-graphical for graphical templates
iso/airootfs/etc/sddm.conf.d/
iso/airootfs/etc/xdg/
iso/airootfs/etc/systemd/system/arches-liveuser.service
iso/airootfs/etc/systemd/system/multi-user.target.wants/arches-liveuser.service
iso/airootfs/etc/systemd/system/display-manager.service
iso/airootfs/etc/systemd/system/sddm.service.d/
iso/airootfs/usr/local/bin/arches-liveuser-setup
iso/airootfs/usr/share/applications/
iso/airootfs/home/

# ─── Generated at build time from platforms/<platform>/ ──
iso/pacman.conf
iso/packages.x86_64
iso/packages.aarch64
iso/airootfs/etc/mkinitcpio.conf.d/archiso.conf
iso/airootfs/etc/pacman.d/hooks/archiso-mkinitcpio-preset.hook
# Generated from .in templates by stage-bootconfig
iso/grub/grub.cfg
iso/grub/loopback.cfg
iso/syslinux/archiso_sys-linux.cfg
iso/syslinux/archiso_pxe-linux.cfg

# ─── Python ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/

# ─── Testing ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
