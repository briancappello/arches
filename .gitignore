# Build artifacts
out/
.pkg-cache/
host-install.log
container-build.log

# ─── Staged into ISO airootfs by Makefile ─────────────
# These are copies of source files (installer/, ansible/, platforms/)
# placed into iso/airootfs/ at build time. The originals are tracked.
iso/airootfs/opt/arches/installer/
iso/airootfs/opt/arches/ansible/
iso/airootfs/opt/arches/platform/
iso/airootfs/usr/local/bin/arches-install

# Pre-built AUR repo (generated by `make aur-repo-*`)
iso/airootfs/opt/arches-repo/

# Cached template packages (generated by `make cache-packages`)
iso/airootfs/opt/arches/pkg-cache/

# Build host SSH key (embedded at build time)
iso/airootfs/opt/arches/build-host.pub

# ─── Generated at build time from platforms/<platform>/ ──
iso/pacman.conf
iso/packages.x86_64
iso/packages.aarch64
iso/airootfs/etc/mkinitcpio.conf.d/archiso.conf
iso/airootfs/etc/pacman.d/hooks/archiso-mkinitcpio-preset.hook
# Generated from .in templates by stage-bootconfig
iso/grub/grub.cfg
iso/syslinux/archiso_sys-linux.cfg

# ─── Python ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/

# ─── Testing ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
