# Load partition table and file system modules
insmod part_gpt
insmod part_msdos
insmod fat
insmod iso9660
insmod ntfs
insmod ntfscomp
insmod exfat
insmod udf

# Use graphics-mode output
if loadfont "${prefix}/fonts/unicode.pf2" ; then
    insmod all_video
    set gfxmode="auto"
    terminal_input console
    terminal_output console
fi

# Enable serial console
insmod serial
insmod usbserial_common
insmod usbserial_ftdi
insmod usbserial_pl2303
insmod usbserial_usbdebug
if serial --unit=0 --speed=115200; then
    terminal_input --append serial
    terminal_output --append serial
fi

# Get a human readable platform identifier
if [ "${grub_platform}" == 'efi' ]; then
    archiso_platform='UEFI'
elif [ "${grub_platform}" == 'pc' ]; then
    archiso_platform='BIOS'
else
    archiso_platform="${grub_cpu}-${grub_platform}"
fi

# Set default menu entry and timeout
default=@DEFAULT_ENTRY@
timeout=5
timeout_style=menu


# ── Boot entries ──────────────────────────────────────
# Generated at build time based on ISO_MODE and auto-install.toml presence.
# Markers @IF_AUTOINSTALL@ and @IF_GRAPHICAL@ are replaced by _stage-bootconfig.

@IF_AUTOINSTALL@menuentry "Arches Linux — Auto Install (%ARCH%, ${archiso_platform})" --class arch --class gnu-linux --class gnu --class os --id 'autoinstall' {
@IF_AUTOINSTALL@    set gfxpayload=keep
@IF_AUTOINSTALL@    linux /%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@ archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% @KERNEL_FLAGS@ systemd.unit=multi-user.target arches.autoinstall=1
@IF_AUTOINSTALL@    initrd /%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
@IF_AUTOINSTALL@}

@IF_GRAPHICAL_AUTOINSTALL@menuentry "Arches Linux — Graphical Auto Install (%ARCH%, ${archiso_platform})" --class arch --class gnu-linux --class gnu --class os --id 'graphical-autoinstall' {
@IF_GRAPHICAL_AUTOINSTALL@    set gfxpayload=keep
@IF_GRAPHICAL_AUTOINSTALL@    linux /%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@ archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% @KERNEL_FLAGS@ arches.autoinstall=1
@IF_GRAPHICAL_AUTOINSTALL@    initrd /%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
@IF_GRAPHICAL_AUTOINSTALL@}

@IF_GRAPHICAL@menuentry "Arches Linux — Graphical Live (%ARCH%, ${archiso_platform})" --class arch --class gnu-linux --class gnu --class os --id 'graphical' {
@IF_GRAPHICAL@    set gfxpayload=keep
@IF_GRAPHICAL@    linux /%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@ archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% @KERNEL_FLAGS@
@IF_GRAPHICAL@    initrd /%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
@IF_GRAPHICAL@}

menuentry "Arches Linux — Framebuffer Installer (%ARCH%, ${archiso_platform})" --class arch --class gnu-linux --class gnu --class os --id 'framebuffer' {
    set gfxpayload=keep
    linux /%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@ archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% @KERNEL_FLAGS@ systemd.unit=multi-user.target
    initrd /%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
}


# ── Utilities ─────────────────────────────────────────

if [ "${grub_platform}" == 'efi' ]; then
    if [ "${grub_cpu}" == 'x86_64' -a -f '/shellx64.efi' ]; then
        menuentry 'UEFI Shell' --class efi {
            chainloader /shellx64.efi
        }
    elif [ "${grub_cpu}" == 'i386' -a -f '/shellia32.efi' ]; then
        menuentry 'UEFI Shell' --class efi {
            chainloader /shellia32.efi
        }
    elif [ "${grub_cpu}" == 'arm64' -a -f '/shellaa64.efi' ]; then
        menuentry 'UEFI Shell' --class efi {
            chainloader /shellaa64.efi
        }
    fi

    if [ -f '/boot/memtest86+/memtest.efi' ]; then
        menuentry 'Memtest86+' --class memtest {
            chainloader /boot/memtest86+/memtest.efi
        }
    fi

    menuentry 'UEFI Firmware Settings' --id 'uefi-firmware' {
        fwsetup
    }
fi

if [ "${grub_platform}" == 'pc' -a -f '/boot/memtest86+/memtest' ]; then
    menuentry 'Memtest86+' --class memtest {
        linux /boot/memtest86+/memtest
    }
fi

menuentry 'System shutdown' --class shutdown --class poweroff {
    echo 'System shutting down...'
    halt
}

menuentry 'System restart' --class reboot --class restart {
    echo 'System rebooting...'
    reboot
}
