LABEL arch_nbd
TEXT HELP
Boot the Arches install/recovery medium using NBD.
ENDTEXT
MENU LABEL Arches (%ARCH%, NBD)
LINUX ::/%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@
INITRD ::/%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
APPEND archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% archiso_nbd_srv=${pxeserver} cms_verify=y video=1920x1080
SYSAPPEND 3

LABEL arch_nfs
TEXT HELP
Boot the Arches install/recovery medium using NFS.
ENDTEXT
MENU LABEL Arches (%ARCH%, NFS)
LINUX ::/%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@
INITRD ::/%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
APPEND archisobasedir=%INSTALL_DIR% archiso_nfs_srv=${pxeserver}:/run/archiso/bootmnt cms_verify=y video=1920x1080
SYSAPPEND 3

LABEL arch_http
TEXT HELP
Boot the Arches install/recovery medium using HTTP.
ENDTEXT
MENU LABEL Arches (%ARCH%, HTTP)
LINUX ::/%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@
INITRD ::/%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
APPEND archisobasedir=%INSTALL_DIR% archiso_http_srv=http://${pxeserver}/ cms_verify=y video=1920x1080
SYSAPPEND 3
