LABEL arch
TEXT HELP
Boot the Arches install/recovery medium on BIOS.
ENDTEXT
MENU LABEL Arches (%ARCH%, BIOS)
LINUX /%INSTALL_DIR%/boot/%ARCH%/vmlinuz-@KERNEL@
INITRD /%INSTALL_DIR%/boot/%ARCH%/initramfs-@KERNEL@.img
APPEND archisobasedir=%INSTALL_DIR% archisosearchuuid=%ARCHISO_UUID% @KERNEL_FLAGS@
